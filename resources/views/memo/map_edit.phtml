      function applyInspectorChange(mutator){
        if(typeof mutator!=='function') return;
        const node=ensureNode();
        if(!node) return;
        performUndoable('update-node-data',()=>{
          commitInlineEditing();
          const data=ensureNodeDataObject(node);
