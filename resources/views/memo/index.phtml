        <span class="modal-count">共 ${counts[c.id]||0}</span>\
        <button class="btn btn-outline btn-small">保存</button>\
        <button class="btn btn-danger btn-small" onclick="return delCat(${c.id}, '${escapeHtml(c.name)}')">删除</button>\
      </form>`;
